{
  "entities": {
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "A message sent from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the sender." },
        "email": { "type": "string", "description": "The email of the sender." },
        "subject": { "type": "string", "description": "The subject of the message." },
        "message": { "type": "string", "description": "The content of the message." },
        "timestamp": { "type": "string", "format": "date-time", "description": "The time the message was sent." }
      },
      "required": ["name", "email", "subject", "message", "timestamp"]
    }
  },
  "firestore": {
    "/contactMessages/{messageId}": {
      "schema": { "$ref": "ContactMessage" },
      "description": "Collection of contact messages."
    }
  }
}
